generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Ticket {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  priority  String
  status    String   @default("Open")
  notes     String?
  createdAt DateTime @default(now())
}